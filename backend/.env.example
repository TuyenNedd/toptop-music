# Database
DATABASE_URL=mysql+aiomysql://root:password@localhost:3306/toptop_music

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT Authentication
JWT_SECRET_KEY=change-me-in-production
JWT_EXPIRY_MINUTES=30

# TikTok API
TIKTOK_MS_TOKEN=your_ms_token_here
VN_PROXY_URL=http://your-proxy:port

# SMTP (Email)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_email@example.com
SMTP_PASSWORD=your_password_here

# Cache Settings
CACHE_MAX_SIZE_GB=10

# Trending Fetch Settings
TRENDING_FETCH_INTERVAL_MINUTES=30
TRENDING_FETCH_COUNT=50
